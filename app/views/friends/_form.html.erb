<%= form_with(model: friend) do |form| %>
  <% if friend.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(friend.errors.count, "error") %> prohibited this friend from being saved:</h2>

      <ul>
        <% friend.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.text_field :first_name, placeholder:"First Name" %>
  </div>

  <div class="mb-3">
    <%= form.text_field :last_name, placeholder:"Last Name"%>
  </div>

  <div class="mb-3">
    <%= form.text_field :email, placeholder:"Email" %>
  </div>

  <div class="mb-3">
    <%= form.text_field :phone, placeholder:"Phone number" %>
  </div>

  <div class="mb-3">
    <%= form.text_field :discord, placeholder:"Discord Username" %>
  </div>

  <%= form.hidden_field :user_id, value: current_user.id %>

  <div>
    <%= form.submit class:"btn btn-secondary" %>
  </div>
<% end %>
